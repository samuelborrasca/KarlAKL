;;karl layout (nokwts version) for rowstag by turtlyn
;;mirrored y keys & repeat key with no magic rules
;;OS shift on pinkies & home row mods

(defcfg
process-unmapped-keys yes
concurrent-tap-hold yes
chords-v2-min-idle 20
windows-altgr cancel-lctl-press
)

;; idk how useful defsrc really is here since i'm using deflayermap
(defsrc 
  вӯҫ q   w   e   r   t   y   u   i   o   p   [   ] 
  вҮӘ  a   s   d   f   g   h   j   k   l   ;   '   \  вҶ©
  вҖ№вҮ§ z   x   c   v   b   n   m   ,   .   /   вҮ§вҖә
                      вҗЈ          ralt 
)

;;в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
;;Layers

