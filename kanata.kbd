rpt v
k m
l ,
, .
. /
вҶ© rsft ;;only defined this so i can use $вҶ© in a combo
вҗЈ вҗЈ
e ralt

lkeys ( 
 $z $p $d $m $y- 
 $n $c $t $s $b
 $q $w $g $rpt 
       $вҗЈ
 )
rkeys (
 $-y $j $u $o $f
 $x $r $i $a $h
 $k $l $, $. 
    $e
 )
)

;;в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
;;Home row mods & layers

(deftemplate flowtap (flow tap)
  (switch 
    ((key-timing 3 less-than 450)) $flow break
    () $tap break
  )
)

(deftemplate mod (char mod keys)
  (defalias $char (t! flowtap 
  				(tap-hold-release-keys $tap-timeout $hold-timeout $char $mod $keys)
  				;;while typing (flow mode = 3 keys pressed in the last 450ms), any key within $keys pressed within timeout will immediately trigger tap action
  				
  				(tap-hold-release-tap-keys-release $tap-timeout $hold-timeout $char $mod () $keys)
  				;;while not in flow mode, any key within $keys pressed AND released within timeout will trigger tap action; lets you stack modifiers
  			   )
   )
)

;;top layer
;;left side
(t! mod n	вҖ№вҺҲ	$lkeys)
(t! mod c	вҖ№вҺҮ	$lkeys)
(t! mod t	вҖ№вқ–	$lkeys)
(t! mod s ralt	$lkeys)
(defalias вҗЈ (t! flowtap 
  			(tap-hold-release-keys $tap-timeout $hold-timeout вҗЈ (layer-while-held sym) $lkeys)			
  			(tap-hold-release $tap-timeout $hold-timeout вҗЈ (layer-while-held sym) )
  		   )
)

;;right side
(t! mod h	вҺҲвҖә	$rkeys)
(t! mod a	вҖ№вҺҮ	$rkeys)
(t! mod i	вқ–вҖә	$rkeys)
(t! mod r 	ralt   $rkeys)
(defalias e (t! flowtap 
  			(tap-hold-release-keys $tap-timeout $hold-timeout e (layer-while-held nav) $rkeys)			
  			(tap-hold-release $tap-timeout $hold-timeout e (layer-while-held nav) )
  		   )
)

;;sym layer
;;left side
(defalias 1 (tap-hold-release $tap-timeout $hold-timeout 1 вҖ№вҺҲ))
(defalias 2 (tap-hold-release $tap-timeout $hold-timeout 2 вҖ№вҺҮ))
(defalias 3 (tap-hold-release $tap-timeout $hold-timeout 3 вҖ№вқ–))
(defalias 4 (tap-hold-release $tap-timeout $hold-timeout 4 ralt))

;;right side
(defalias / (tap-hold-release $tap-timeout $hold-timeout / вҺҲвҖә))
(defalias = (tap-hold-release $tap-timeout $hold-timeout = вҖ№вҺҮ))
(defalias - (tap-hold-release $tap-timeout $hold-timeout - вқ–вҖә))
(defalias ] (tap-hold-release $tap-timeout $hold-timeout ] ralt))
